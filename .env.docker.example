# ═══════════════════════════════════════════════════════════
#  MedAI — Docker Compose Environment
#  Copy this file:  cp .env.docker.example .env
#  Then fill in your ANTHROPIC_API_KEY below.
# ═══════════════════════════════════════════════════════════

# ─── REQUIRED ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ─── Secrets ───────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string

# ─── Feature Toggles ──────────────────────────────────────
DEBUG=true
LOG_LEVEL=INFO

# ─── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ─── Frontend ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
