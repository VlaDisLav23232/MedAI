# ═══════════════════════════════════════════════════════════
#  MedAI Backend — Environment Configuration
#  Copy this file: cp .env.example .env
#  Then fill in your ANTHROPIC_API_KEY below.
# ═══════════════════════════════════════════════════════════

# ─── REQUIRED: Anthropic API Key ────────────────────────────
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ─── Claude Model Config ───────────────────────────────────
ORCHESTRATOR_MODEL=claude-sonnet-4-20250514
ORCHESTRATOR_MAX_TOKENS=8192
JUDGE_MAX_TOKENS=4096

# ─── Feature Toggles ──────────────────────────────────────
# Set DEBUG=true for mock mode (no GPU endpoints needed)
DEBUG=true
JUDGE_ENABLED=true
ENABLE_27B_REASONING=true
MAX_JUDGMENT_CYCLES=1

# ─── Tool Endpoints (Modal GPU) ───────────────────────────
# Only required when DEBUG=false (real mode).
# Deploy models first: bash deploy/modal/deploy_all.sh
# Then paste the URLs Modal gives you here.
MEDGEMMA_4B_ENDPOINT=https://YOUR_USERNAME--medai-medgemma-4b-medgemma4b-predict.modal.run
MEDGEMMA_27B_ENDPOINT=https://YOUR_USERNAME--medai-medgemma-27b-medgemma27b-predict.modal.run
MEDSIGLIP_ENDPOINT=https://YOUR_USERNAME--medai-siglip-explainability-siglipexplainabil-XXXXX.modal.run
HEAR_ENDPOINT=https://YOUR_USERNAME--medai-hear-audio-hearaudio-predict.modal.run
MEDASR_ENDPOINT=https://YOUR_USERNAME--medai-medasr-medasr-predict.modal.run

# ─── Database ──────────────────────────────────────────────
# SQLite for local dev (auto-created), PostgreSQL for production
DATABASE_URL=sqlite+aiosqlite:///./medai.db

# ─── Storage ───────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage

# ─── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ─── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ─── Auth ──────────────────────────────────────────────────
# JWT_SECRET is auto-generated if not set. Set it for production.
# JWT_SECRET=your-secret-here
