# ─── Required ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# ─── Optional: Model Config ────────────────────────────────
ORCHESTRATOR_MODEL=claude-sonnet-4-5-20250929
ORCHESTRATOR_MAX_TOKENS=4096
JUDGE_MAX_TOKENS=2048

# ─── Optional: Tool Endpoints (Modal / self-hosted) ────────
MEDGEMMA_4B_ENDPOINT=http://localhost:8010
MEDGEMMA_27B_ENDPOINT=http://localhost:8011
MEDSIGLIP_ENDPOINT=http://localhost:8012
HEAR_ENDPOINT=http://localhost:8013

# ─── Optional: Database ────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./medai.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/medai

# ─── Optional: Storage ─────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage

# ─── Optional: Server ──────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
DEBUG=true
